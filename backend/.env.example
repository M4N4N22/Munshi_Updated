PORT=4001
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# PostgreSQL (Supabase session pooler, Railway Postgres, or local)
POSTGRES_CONNECTION_STRING=postgresql://postgres.PROJECT_REF:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres?sslmode=require

# ML service (Railway private URL in staging/prod)
ML_URL=http://localhost:8000

# Web app URL (Vercel) — used for Zoho OAuth redirect and CSV template links
MUNSHI_WEB_URL=http://localhost:3000

# Team / inventory CSV templates (optional overrides; defaults use MUNSHI_WEB_URL)
# MUNSHI_TEAM_CSV_TEMPLATE_URL=
# MUNSHI_INVENTORY_CSV_TEMPLATE_URL=
MUNSHI_TEAM_DASHBOARD_URL=https://munshi-dada.vercel.app

# Legacy Google Form (optional ops link only)
ONBOARD_WORKER_GOOGLE_FORM_URL=

# Owner home — demo links (plain text in WhatsApp)
MUNSHI_BOOK_DEMO_URL=
MUNSHI_DEMO_YOUTUBE_URL=

# WhatsApp (Olli)
WHATSAPP_VERIFY_TOKEN=change-me
OLLI_URL=https://api.getolliai.com/api/v1
OLLI_KEY=
# OLLI_MEDIA_BASE_URL=https://api.getolliai.com

# Internal API auth (required for /resolve/* and other internal routes)
X_SECRET=change-me-in-production

# OTP hashing pepper (production: long random secret)
OTP_PEPPER=

# OTP SMS via MSG91 (required for production web onboarding SMS)
ONBOARDING_MSG91_AUTH_KEY=
ONBOARDING_MSG91_TEMPLATE_ID=
# Dev only: return OTP in API JSON (default: true when NODE_ENV !== production)
# ONBOARDING_OTP_EXPOSE_IN_RESPONSE=false

# Dev only: enable POST /webhook/test (disabled in production by default)
# ENABLE_WEBHOOK_TEST_ROUTE=true

# Zoho Inventory OAuth (Phase 2)
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
ZOHO_REDIRECT_URI=http://localhost:4001/integrations/zoho/callback
ZOHO_ACCOUNTS_URL=https://accounts.zoho.in
INTEGRATION_TOKEN_ENCRYPTION_KEY=
# ZOHO_INVENTORY_API_DOMAIN=https://www.zohoapis.in
ZOHO_SYNC_ENABLED=true
ZOHO_SYNC_INTERVAL_MINUTES=360

# Optional
# DOCUMENT_STORAGE_PATH=./uploads
# WORKFLOW_SESSION_TTL_HOURS=24
# WHATSAPP_TOKEN=
# WHATSAPP_PHONE_NUMBER_ID=
# WHATSAPP_ONBOARDING_TEMPLATE=
# AUTO_MIGRATE=1
# SKIP_MIGRATION_BOOTSTRAP=0
