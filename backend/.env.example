PORT=4001
CORS_ORIGIN=http://localhost:3000,http://localhost:3001

# Supabase (Session pooler, port 5432) or any PostgreSQL
POSTGRES_CONNECTION_STRING=postgresql://postgres.PROJECT_REF:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres?sslmode=require

ML_URL=http://localhost:8000

# Legacy Google Form (retired in UX — optional ops link only)
ONBOARD_WORKER_GOOGLE_FORM_URL=
MUNSHI_TEAM_DASHBOARD_URL=https://munshi-dada.vercel.app

# Team CSV template (static on Vercel: web/public/team-import/munshi-team-template.csv)
# Default: https://munshi-dada.vercel.app/team-import/munshi-team-template.csv
# MUNSHI_TEAM_CSV_TEMPLATE_URL=
MUNSHI_WEB_URL=https://munshi-dada.vercel.app
# Inventory CSV template (static on Vercel: web/public/inventory-import/munshi-inventory-template.csv)
# Default: ${MUNSHI_WEB_URL}/inventory-import/munshi-inventory-template.csv
# MUNSHI_INVENTORY_CSV_TEMPLATE_URL=
# MUNSHI_PUBLIC_API_HOST=https://your-tunnel.trycloudflare.com

# Owner home — demo links (plain text in WhatsApp; same as web onboarding)
MUNSHI_BOOK_DEMO_URL=
MUNSHI_DEMO_YOUTUBE_URL=

WHATSAPP_VERIFY_TOKEN=change-me
OLLI_URL=https://api.getolliai.com/api/v1
OLLI_KEY=
# Optional: override host for relative /uploads/waba-media/... paths from webhooks
# OLLI_MEDIA_BASE_URL=https://api.getolliai.com

X_SECRET=secret

# OTP hashing pepper (production: set a long random secret)
OTP_PEPPER=

# Zoho Inventory OAuth (Phase 2.2)
ZOHO_CLIENT_ID=
ZOHO_CLIENT_SECRET=
# Must match Zoho developer app redirect URI — typically the Nest callback URL
ZOHO_REDIRECT_URI=http://localhost:4001/integrations/zoho/callback
# Zoho accounts host for your data center (e.g. https://accounts.zoho.in or https://accounts.zoho.com)
ZOHO_ACCOUNTS_URL=https://accounts.zoho.in
# AES-256-GCM key material for integration token encryption and OAuth state signing (32+ chars recommended)
INTEGRATION_TOKEN_ENCRYPTION_KEY=
# Web app URL for post-OAuth redirect (integrations page)
MUNSHI_WEB_URL=http://localhost:3000
# Optional fallback when connection metadata lacks api_domain
# ZOHO_INVENTORY_API_DOMAIN=https://www.zohoapis.in

# Scheduled Zoho pull sync (Phase 2.4)
ZOHO_SYNC_ENABLED=true
ZOHO_SYNC_INTERVAL_MINUTES=360
