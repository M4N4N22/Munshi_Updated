{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "StockRegisterExtraction",
  "type": "object",
  "required": ["document_type", "items"],
  "properties": {
    "document_type": { "const": "STOCK_REGISTER" },
    "as_of_date": { "type": "string" },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "quantity": { "type": "number", "minimum": 0 },
          "sku": { "type": "string" },
          "unit": { "type": "string" }
        }
      }
    }
  }
}
