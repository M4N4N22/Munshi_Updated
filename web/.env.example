# Munshi API (Railway backend in staging; api.munshidada.com when configured)
NEXT_PUBLIC_API_URL=http://localhost:4001

# WhatsApp Business number (91 + 10 digits) — wa.me target
NEXT_PUBLIC_WHATSAPP_BUSINESS_NUMBER=919876543210
WHATSAPP_BUSINESS_NUMBER=919876543210

# Optional marketing links
NEXT_PUBLIC_BOOK_DEMO_URL=https://cal.com/your-link
NEXT_PUBLIC_YOUTUBE_URL=https://www.youtube.com/watch?v=

# Leads admin (/admin, /api/leads) — Turso (libSQL)
TURSO_DATABASE_URL=
TURSO_AUTH_TOKEN=

# Admin dashboards (/admin, /admin/clients) — x-admin-key from browser
ADMIN_SECRET_KEY=

# Server-only: proxies /api/admin/clients → backend GET /admin/clients
X_SECRET=
