{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "InventoryImportExtraction",
  "type": "object",
  "required": ["document_type", "items"],
  "properties": {
    "document_type": { "const": "INVENTORY_IMPORT" },
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": ["name"],
        "properties": {
          "name": { "type": "string", "minLength": 1 },
          "quantity": { "type": "number", "minimum": 0 },
          "sku": { "type": "string" },
          "unit": { "type": "string" },
          "category_name": { "type": "string" },
          "location_name": { "type": "string" }
        }
      }
    }
  }
}
