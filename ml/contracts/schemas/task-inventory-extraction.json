{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "TaskInventoryExtraction",
  "description": "Phase 4.1 structured output for natural-language inventory-linked task messages",
  "type": "object",
  "required": [
    "item_name_or_sku",
    "quantity",
    "assignee_hint",
    "task_kind"
  ],
  "properties": {
    "item_name_or_sku": {
      "type": ["string", "null"],
      "minLength": 1
    },
    "quantity": {
      "type": ["number", "null"],
      "minimum": 0
    },
    "assignee_hint": {
      "type": ["string", "null"],
      "minLength": 1
    },
    "task_kind": {
      "type": ["string", "null"],
      "enum": ["delivery", "issue", "inventory_count", null]
    }
  },
  "additionalProperties": false
}
