# Copy to .env on the VM (/home/ubuntu/munshi-dada/.env) and fill secrets.
# Database: Supabase only in production (see docs/p0-production-database.md).

PORT=4001
CORS_ORIGIN=https://www.munshidada.com,https://munshidada.com

POSTGRES_CONNECTION_STRING=postgresql://postgres.PROJECT_REF:YOUR_PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres?sslmode=require

# Set in docker-compose.yml (backend -> ml on Docker network). Do not change unless ML is external.
# ML_URL=http://ml:8000

MUNSHI_TEAM_DASHBOARD_URL=https://www.munshidada.com
MUNSHI_WEB_URL=https://www.munshidada.com
# Public URL Olli / webhooks hit (domain or http://VM_IP:4001)
MUNSHI_PUBLIC_API_HOST=https://YOUR_PUBLIC_API_HOST

WHATSAPP_VERIFY_TOKEN=change-me
OLLI_URL=https://api.getolliai.com/api/v1
OLLI_KEY=
OLLI_MEDIA_BASE_URL=https://api.getolliai.com

X_SECRET=change-me-long-random
OTP_PEPPER=change-me-long-random

# Optional MSG91 for web OTP (if using onboarding SMS)
# ONBOARDING_MSG91_AUTH_KEY=
# ONBOARDING_MSG91_TEMPLATE_ID=
